# Development environment example for FYWarehouse Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SMTP delivery placeholders for src/app/api/contact/route.ts
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=apikey-or-username
EMAIL_SERVER_PASSWORD=replace-me
EMAIL_FROM=FYWarehouse Website <no-reply@fywarehouse.com>
EMAIL_TO=ops@fywarehouse.com

# Optional contact API hardening notes
# - POST /api/contact performs same-origin checks, input sanitization, spam filtering,
#   in-memory rate limiting (3 submissions per minute per IP by default), and structured mail logs.
# - ALLOWED_ORIGIN can override the accepted origin host in production previews or custom domains.
# - CONTACT_RATE_LIMIT_WINDOW_MS and CONTACT_RATE_LIMIT_MAX are optional tunables.
ALLOWED_ORIGIN=http://localhost:3000
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX=3

# Google Maps JavaScript API placeholder for src/components/Map/Map.tsx
# Request your own key in Google Cloud Console, enable Maps JavaScript API, and store it in .env.local for development.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional analytics placeholders
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=
