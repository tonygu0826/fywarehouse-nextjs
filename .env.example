# Development environment example for FYWarehouse Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SMTP delivery placeholders for src/app/api/contact/route.ts
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=apikey-or-username
EMAIL_SERVER_PASSWORD=replace-me
EMAIL_SERVER_SECURE=false
EMAIL_FROM=FYWarehouse Website <no-reply@fywarehouse.com>
EMAIL_TO=ops@fywarehouse.com

# Optional contact API hardening notes
# - POST /api/contact performs same-origin checks, input sanitization, spam filtering,
#   in-memory rate limiting (3 submissions per minute per IP by default), and structured mail logs.
# - ALLOWED_ORIGIN can override the accepted origin host in production previews or custom domains.
# - CONTACT_RATE_LIMIT_WINDOW_MS and CONTACT_RATE_LIMIT_MAX are optional tunables.
ALLOWED_ORIGIN=http://localhost:3000
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX=3

# Google Maps JavaScript API placeholder for src/components/Map/Map.tsx
# Request your own key in Google Cloud Console, enable Maps JavaScript API, and store it in .env.local for development.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional analytics placeholders
# GA4 example: G-XXXXXXXXXX
# GTM example: GTM-XXXXXXX
# Reference from original site analysis only (do not reuse blindly): GT-KFN9SQ8
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ==================== News & SEO Automation ====================
# API key for news management endpoints (POST/PUT/DELETE)
NEWS_API_KEY=replace-with-secure-key
# Number of articles to auto-generate per daily run
NEWS_DAILY_COUNT=3
# Auto-publish generated articles (false = save as draft)
NEWS_AUTO_PUBLISH=false

# Arvo API integration (optional, for enhanced article generation)
ARVO_API_KEY=
ARVO_API_URL=

# Blotato social media scheduling API
BLOTATO_API_KEY=
BLOTATO_API_URL=https://api.blotato.com/v1

# ==================== FYMail Skills System Configuration ====================
# FYMail Skills System Configuration
# Skills discovery and registration
SKILLS_DIRECTORY=/home/ubuntu/.openclaw/workspace/skills
SKILLS_AUTO_DISCOVER=true
SKILLS_DISCOVERY_INTERVAL_MINUTES=60
SKILLS_MAX_SKILLS=50

# Skills execution and performance
SKILLS_CONCURRENCY=3
SKILLS_TIMEOUT_MS=30000
SKILLS_PERFORMANCE_MONITORING=true
SKILLS_PERFORMANCE_SAMPLING_RATE=0.1

# Contact enrichment pipeline
ENRICHMENT_ENABLED=true
ENRICHMENT_MAX_RETRIES=3
ENRICHMENT_RETRY_DELAY_MS=1000
ENRICHMENT_CACHE_TTL_SECONDS=3600
ENRICHMENT_CACHE_ENABLED=true

# Bulk send strategy recommendations
STRATEGY_RECOMMENDATIONS_ENABLED=true
STRATEGY_RECOMMENDATIONS_CACHE_TTL=300
STRATEGY_HISTORICAL_DATA_RETENTION_DAYS=90

# Monitoring and alerts
MONITORING_ENABLED=true
ALERT_EMAIL_RECIPIENT=admin@example.com
ALERT_COOLDOWN_MINUTES=30
PERFORMANCE_ALERTS_ENABLED=true

# A/B testing
AB_TESTING_ENABLED=true
AB_TESTING_AUTO_ASSIGN=true
AB_TESTING_TRACKING_WINDOW_HOURS=72
AB_TESTING_MINIMUM_SAMPLE_SIZE=100

# Health check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT_MS=5000
HEALTH_CHECK_DEPENDENCIES=true

# Logging
SKILLS_LOG_LEVEL=info
SKILLS_STRUCTURED_LOGGING=false
SKILLS_LOG_FILE_PATH=
