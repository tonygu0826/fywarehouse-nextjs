# FYWarehouse production environment template
# Copy values into Vercel Project Settings -> Environment Variables.
# Do not commit real secrets.

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://www.fywarehouse.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# SMTP delivery for src/app/api/contact/route.ts
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=apikey-or-username
EMAIL_SERVER_PASSWORD=replace-with-production-secret
EMAIL_FROM=FY Warehouse Website <no-reply@fywarehouse.com>
EMAIL_TO=ops@fywarehouse.com

# Contact form / runtime hardening
ALLOWED_ORIGIN=https://www.fywarehouse.com
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX=3

# Analytics placeholders
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional deployment metadata
VERCEL_PROJECT_PRODUCTION_URL=www.fywarehouse.com
