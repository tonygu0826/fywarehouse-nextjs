{
  "name": "fywarehouse-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm install && next build",
    "cf-build": "npx @cloudflare/next-on-pages",
    "cf-deploy": "wrangler pages deploy .vercel/output/static --project-name=fywarehouse-mail"
  },
  "browserslist": {
    "production": [
      "chrome >= 109",
      "edge >= 109",
      "firefox >= 115",
      "ios_saf >= 15.6",
      "safari >= 15.6"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "google-ads-api": "^23.0.0",
    "google-auth-library": "^10.6.2",
    "next": "14.2.30",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.72.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.30",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "typescript": "^5.9.2"
  }
}
